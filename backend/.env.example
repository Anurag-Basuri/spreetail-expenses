# Database Connection
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/equisplit

# Security Settings
# Generate a secret key in prod using: openssl rand -hex 32
SECRET_KEY=your_development_secret_key_change_me_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Defaults
USD_TO_INR_RATE=84.0
PERCENTAGE_TOLERANCE=0.01
